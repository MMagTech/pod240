{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pod240",
  "version": "0.1.2",
  "identifier": "com.pod240.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pod240",
        "width": 800,
        "height": 1100,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/presets",
      "resources/handbrake",
      "resources/atomicparsley",
      "resources/ffmpeg"
    ]
  }
}
